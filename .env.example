# Server Port
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shoperydb?schema=public"

# Authentication Secrets (MUST be randomly generated cryptographically strong strings for production)
ACCESS_TOKEN_SECRET="generate_a_random_256_bit_string"
REFRESH_TOKEN_SECRET="generate_a_random_256_bit_string"
SESSION_SECRET="generate_a_random_string_for_sessions"
CSRF_SECRET="generate_a_random_256_bit_string_for_csrf"

# Password Hashing
BCRYPT_SALT_ROUNDS="12"

# External Services
BREVO_API_KEY="your_brevo_api_key_here"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_BASE_FOLDER="shopery-upload"

# Other Settings
NODE_ENV="development"
GUEST_CART_TOKEN="guest_token"
SMTP_FROM="your_email@example.com"
EMAIL_WORKER_URL="your_cloudflare_worker_url"
EMAIL_PROVIDER="worker"
